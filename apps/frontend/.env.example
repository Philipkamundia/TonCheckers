# Backend API URL
VITE_API_URL=https://your-backend.railway.app

# WebSocket URL (same as API for Socket.IO)
VITE_WS_URL=https://your-backend.railway.app

# Your Telegram Mini App URL (used for TonConnect manifest)
VITE_APP_URL=https://your-app.telegram.com

# Optional — leave blank to disable Sentry error tracking
VITE_SENTRY_DSN=
