{
  "name": "@checkton/backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev":     "tsx watch src/index.ts",
    "build":   "tsc",
    "start":   "node dist/src/index.js",
    "migrate": "tsx scripts/migrate.ts",
    "seed":    "tsx scripts/seed.ts",
    "lint":    "eslint src --ext .ts --report-unused-disable-directives --max-warnings 0",
    "test":    "vitest run",
    "clean":   "rimraf dist"
  },
  "dependencies": {
    "@ton/core":         "^0.62.0",
    "@ton/crypto":       "^3.3.0",
    "@ton/ton":          "^15.3.1",
    "@tonconnect/sdk":   "^3.3.0",
    "@sentry/node":      "^8.0.0",
    "axios":             "^1.12.2",
    "compression":       "^1.7.4",
    "cors":              "^2.8.5",
    "dotenv":            "^16.3.1",
    "express":           "^4.18.2",
    "express-rate-limit":"^8.1.0",
    "helmet":            "^7.0.0",
    "ioredis":           "^5.3.2",
    "jsonwebtoken":      "^9.0.2",
    "morgan":            "^1.10.0",
    "node-cron":         "^4.2.1",
    "pg":                "^8.19.0",
    "socket.io":         "^4.7.2",
    "winston":           "^3.10.0",
    "zod":               "^3.22.2"
  },
  "devDependencies": {
    "@types/compression":  "^1.7.3",
    "@types/cors":         "^2.8.13",
    "@types/express":      "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan":       "^1.9.4",
    "@types/node":         "^20.5.0",
    "@types/pg":           "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser":        "^6.0.0",
    "eslint":    "^8.45.0",
    "rimraf":    "^5.0.1",
    "tsx":       "^3.12.7",
    "typescript":"^5.0.2",
    "vitest":    "^0.34.1"
  }
}
