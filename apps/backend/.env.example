# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/checkton

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-32-char-string-minimum
JWT_REFRESH_SECRET=change-this-to-a-different-32-char-string
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather
TELEGRAM_BOT_SECRET=your-bot-webhook-secret
ADMIN_BOT_TOKEN=your-admin-bot-token-from-botfather

# ─── TON Network ──────────────────────────────────────────────────────────────
TON_NETWORK=testnet
TON_API_KEY=your-toncenter-api-key

# ─── Treasury Wallets ─────────────────────────────────────────────────────────
# Hot wallet — processes withdrawals, receives deposits
HOT_WALLET_ADDRESS=EQD...
HOT_WALLET_MNEMONIC=word1 word2 word3 ... word24

# Cold wallet — long-term storage
COLD_WALLET_ADDRESS=EQD...

# Admin (treasury) wallet — used to authenticate admin dashboard
TREASURY_WALLET_ADDRESS=EQD...

# ─── Game Config ──────────────────────────────────────────────────────────────
PLATFORM_FEE_PERCENT=15
TOURNAMENT_PLATFORM_FEE_PERCENT=25
TOURNAMENT_CREATOR_FEE_PERCENT=5
MIN_DEPOSIT_TON=0.5
MIN_STAKE_TON=0.1
MAX_DAILY_WITHDRAWAL_TON=100

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.telegram.com

# ─── Observability ────────────────────────────────────────────────────────────
# Optional — leave blank to disable Sentry error tracking
SENTRY_DSN=
